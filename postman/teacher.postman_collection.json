{
  "info": {
    "_postman_id": "a2c0e2f2-7f1d-4d2f-8b50-3b1df8cbd5f1",
    "name": "School Exam - Teacher API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Teacher module endpoints"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "bankId", "value": "" },
    { "key": "questionId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/v1/auth/login (teacher)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try { var data = pm.response.json(); if (data && data.token) { pm.collectionVariables.set('token', data.token); } } catch(e) {}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"<teacher_username>\",\n  \"password\": \"<teacher_password>\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","login"] }
          }
        }
      ]
    },
    {
      "name": "Question Banks",
      "item": [
        {
          "name": "POST /api/v1/teacher/question-banks",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try { var data = pm.response.json(); if (data && data.id) { pm.collectionVariables.set('bankId', data.id); } } catch(e) {}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"subject_id\": \"<subject_id>\",\n  \"title\": \"Algebra I\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/teacher/question-banks", "host": ["{{baseUrl}}"], "path": ["api","v1","teacher","question-banks"] }
          }
        },
        {
          "name": "GET /api/v1/teacher/question-banks",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/teacher/question-banks?page=1&page_size=20", "host": ["{{baseUrl}}"], "path": ["api","v1","teacher","question-banks"], "query": [{"key":"page","value":"1"},{"key":"page_size","value":"20"}] }
          }
        }
      ]
    },
    {
      "name": "Questions",
      "item": [
        {
          "name": "POST /api/v1/teacher/questions",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try { var data = pm.response.json(); if (data && data.id) { pm.collectionVariables.set('questionId', data.id); } } catch(e) {}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"question_bank_id\": \"{{bankId}}\",\n  \"type\": \"mcq\",\n  \"question_text\": \"2+2= ?\",\n  \"marks\": 1,\n  \"difficulty_level\": \"easy\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/teacher/questions", "host": ["{{baseUrl}}"], "path": ["api","v1","teacher","questions"] }
          }
        },
        {
          "name": "GET /api/v1/teacher/questions?bank_id={{bankId}}",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/teacher/questions?bank_id={{bankId}}&page=1&page_size=20", "host": ["{{baseUrl}}"], "path": ["api","v1","teacher","questions"], "query": [{"key":"bank_id","value":"{{bankId}}"},{"key":"page","value":"1"},{"key":"page_size","value":"20"}] }
          }
        },
        {
          "name": "PATCH /api/v1/teacher/questions",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"id\": \"{{questionId}}\",\n  \"question_text\": \"2+3= ?\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/teacher/questions", "host": ["{{baseUrl}}"], "path": ["api","v1","teacher","questions"] }
          }
        },
        {
          "name": "DELETE /api/v1/teacher/questions/:id",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/v1/teacher/questions/{{questionId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","teacher","questions","{{questionId}}"] }
          }
        }
      ]
    },
    {
      "name": "Options",
      "item": [
        {
          "name": "POST /api/v1/teacher/options",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"question_id\": \"{{questionId}}\",\n  \"option_text\": \"4\",\n  \"is_correct\": true\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/teacher/options", "host": ["{{baseUrl}}"], "path": ["api","v1","teacher","options"] }
          }
        },
        {
          "name": "GET /api/v1/teacher/options?question_id={{questionId}}",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/teacher/options?question_id={{questionId}}&page=1&page_size=20", "host": ["{{baseUrl}}"], "path": ["api","v1","teacher","options"], "query": [{"key":"question_id","value":"{{questionId}}"},{"key":"page","value":"1"},{"key":"page_size","value":"20"}] }
          }
        },
        {
          "name": "PATCH /api/v1/teacher/options",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"id\": \"<option_id>\",\n  \"option_text\": \"5\",\n  \"is_correct\": false\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/teacher/options", "host": ["{{baseUrl}}"], "path": ["api","v1","teacher","options"] }
          }
        },
        {
          "name": "DELETE /api/v1/teacher/options/:id",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/v1/teacher/options/<option_id>", "host": ["{{baseUrl}}"], "path": ["api","v1","teacher","options","<option_id>"] }
          }
        }
      ]
    },
    {
      "name": "Students",
      "item": [
        {
          "name": "GET /api/v1/teacher/students",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/teacher/students?page=1&page_size=20", "host": ["{{baseUrl}}"], "path": ["api","v1","teacher","students"], "query": [{"key":"page","value":"1"},{"key":"page_size","value":"20"}] }
          }
        }
      ]
    }
  ]
}
