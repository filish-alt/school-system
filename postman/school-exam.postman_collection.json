                  "path": ["api", "v1", "superadmin", "students", "<student_id>"]
                }
              }
            },
            {
              "name": "DELETE /api/v1/superadmin/students/:id",
              "request": {
                "method": "DELETE",
                "url": {
                  "raw": "{{baseUrl}}/api/v1/superadmin/students/<student_id>",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "superadmin", "students", "<student_id>"]
                }
              }
            },
            {
              "name": "POST /api/v1/superadmin/students/import",
              "request": {
                "method": "POST",
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "tenant_id", "value": "{{tenantId}}", "type": "text" },
                    { "key": "file", "type": "file", "src": "examples/students.csv" }
                  ]
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/superadmin/students/import",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "superadmin", "students", "import"]
                }
              }
            }
          ]
