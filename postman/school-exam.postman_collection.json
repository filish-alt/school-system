                  "raw": "{\n  \"tenant_id\": \"{{tenantId}}\",\n  \"student_code\": \"STU-001\",\n  \"first_name\": \"Lisa\",\n  \"last_name\": \"Simpson\",\n  \"email\": \"lisa@example.com\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/superadmin/students",
